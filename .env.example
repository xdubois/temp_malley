# Copy to .env and fill in (the app calls the secret "Key"). .env is gitignored.
# For local runs only — in CI these are GitHub repo secrets, not this file.
#   cp .env.example .env
#   uv run --env-file .env fetch_sensor.py --list   # find your Hub 2 deviceId
#   uv run --env-file .env fetch_sensor.py           # poll + append one row
SWITCHBOT_TOKEN=your-open-token
SWITCHBOT_SECRET=your-key
SWITCHBOT_DEVICE=hub2-device-id-from---list
